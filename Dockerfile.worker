# ─────────────────────────────────────────────────────────────────────────────
# Dockerfile.worker
# Cloud Run / ローカルGPUサーバー: ADKエージェントワーカー
# 内包ツール: git, gh (GitHub CLI), Python (aider), Node.js (tsx / ADK)
#
# 注意: このプロジェクトは pnpm workspace (ルートに単一の pnpm-lock.yaml) 構成。
# `--frozen-lockfile` でのインストールにはワークスペース全体の
# マニフェスト (pnpm-workspace.yaml + 各メンバーのpackage.json) が必要になる。
# ─────────────────────────────────────────────────────────────────────────────
FROM node:20-slim AS base

# ── システムパッケージ ──────────────────────────────────────────────────────
RUN apt-get update && apt-get install -y --no-install-recommends \
    git \
    curl \
    ca-certificates \
    python3 \
    python3-pip \
    python3-venv \
    gnupg \
    lsb-release \
    && rm -rf /var/lib/apt/lists/*

# ── GitHub CLI ────────────────────────────────────────────────────────────
RUN curl -fsSL https://cli.github.com/packages/githubcli-archive-keyring.gpg \
      | dd of=/usr/share/keyrings/githubcli-archive-keyring.gpg \
    && echo "deb [arch=$(dpkg --print-architecture) signed-by=/usr/share/keyrings/githubcli-archive-keyring.gpg] https://cli.github.com/packages stable main" \
      | tee /etc/apt/sources.list.d/github-cli.list > /dev/null \
    && apt-get update \
    && apt-get install -y gh \
    && rm -rf /var/lib/apt/lists/*

# ── pnpm + tsx ────────────────────────────────────────────────────────────
RUN npm install -g pnpm tsx

# ── Python仮想環境: Aider (LOCAL_AIDERモード用) ─────────────────────────
ENV VENV_PATH=/opt/venv
RUN python3 -m venv $VENV_PATH
ENV PATH="$VENV_PATH/bin:$PATH"
RUN pip install --no-cache-dir aider-chat && pip cache purge

# ── アプリケーション ──────────────────────────────────────────────────────
WORKDIR /app

# ワークスペース全体のマニフェストをコピー (依存解決に必要。ソースコードはまだコピーしない)
COPY pnpm-workspace.yaml package.json pnpm-lock.yaml ./
COPY gcp-webhook/package.json ./gcp-webhook/
COPY cloudflare-workers/package.json ./cloudflare-workers/
COPY local-worker/package.json ./local-worker/
COPY local-dev/cf-queue-mock/package.json ./local-dev/cf-queue-mock/
COPY local-dev/gcp-pubsub-relay/package.json ./local-dev/gcp-pubsub-relay/
COPY local-test/package.json ./local-test/

RUN pnpm install --frozen-lockfile --prod

COPY src/worker-entrypoint.ts ./src/
COPY tsconfig.worker.json ./tsconfig.json

# Gitグローバル設定
RUN git config --global user.email "devops-ai-agent@bot.local" \
    && git config --global user.name "DevOps AI Agent"

ENV NODE_ENV=production

CMD ["tsx", "src/worker-entrypoint.ts"]
