# ─────────────────────────────────────────────────────────────────────────────
# .env.example
# cp .env.example .env.local して値を入力してください
# ─────────────────────────────────────────────────────────────────────────────

# ── 共通 ──────────────────────────────────────────────────────────────────────
# 構成B (ローカルAider) や、構成AでGitHub Appを使わない場合の後方互換フォールバック用。
# GitHub Appを使う場合 (推奨) はこの値は不要。
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx

# ── ローカルワーカーサーバー (構成B) ─────────────────────────────────────────
PORT=3434
# Cloudflare Workers と共有する認証トークン (openssl rand -hex 32 で生成)
LOCAL_WORKER_TOKEN=your-random-secret-token-here
MAX_CONCURRENT=1

# ── ローカル動作確認 (共通) ───────────────────────────────────────────────────
# true にすると git clone/push/PR作成・Aider/ADKの実行を全てスキップし、
# ログ出力のみで処理をシミュレートする (HTTP層・認証・Queueリレーの疎通確認用)。
# docker-compose.dev.cloudflare.yml / docker-compose.dev.gcp.yml ではデフォルトtrue。
DRY_RUN=false

# ── Aider + Ollama ────────────────────────────────────────────────────────────
AIDER_MODEL=qwen2.5-coder:32b
OLLAMA_API_BASE=http://localhost:11434/v1

# ── 構成A: Google Cloud ───────────────────────────────────────────────────────
# (Cloud Run上では Secret Manager から自動取得)
# 下記は実際のGCPプロジェクトIDに書き換えること (プロジェクト"名"ではない)。
# 未設定/プレースホルダーのままだと `task gcp:setup` 等が
# "Project 'your-gcp-project-id' not found" エラーで停止する。
# プロジェクトIDの確認・作成方法は README.md の
# 「GCPの初期セットアップ (Google Cloud Console)」を参照。
# 確認コマンド: gcloud projects list
GCP_PROJECT=your-gcp-project-id
GEMINI_MODEL=gemini-2.0-flash
AGENT_MODE=GEMINI_ADK

# ── GitHub App (PATを使わずに他リポジトリへ展開するための認証方式・推奨) ──────
# 作成方法は README.md の「GitHub Appを使った他リポジトリへの展開」を参照。
# App ID (数字)。Cloud Runの環境変数としてそのまま設定される (機密情報ではない)
GITHUB_APP_ID=123456
# 秘密鍵(.pem)は基本的にローカルの.envには置かず、Secret Managerに直接登録する:
#   gcloud secrets versions add GITHUB_APP_PRIVATE_KEY --data-file=path/to/private-key.pem
# ただしDockerを使わずローカルで直接 tsx src/worker-entrypoint.ts を動かして
# 動作確認したい場合のみ、ここにPEMの中身をそのまま (改行含めて) 貼り付けてもよい。
# GITHUB_APP_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----"

# 処理を許可するリポジトリのカンマ区切りリスト (owner/repo,owner/repo)。
# 空のままだとAppをインストールした全リポジトリを許可する。
# Any accountにインストール可能な設定にしている場合は、
# 想定外のリポジトリでのCloud Run/Gemini APIの実行コストを防ぐため設定を推奨。
ALLOWED_REPOS=owner/repo1,owner/repo2
