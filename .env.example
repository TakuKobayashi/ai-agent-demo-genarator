# ─────────────────────────────────────────────────────────────────────────────
# .env.example
# cp .env.example .env.local して値を入力してください
# ─────────────────────────────────────────────────────────────────────────────

# ── 共通 ──────────────────────────────────────────────────────────────────────
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx

# ── ローカルワーカーサーバー (構成B) ─────────────────────────────────────────
PORT=3434
# Cloudflare Workers と共有する認証トークン (openssl rand -hex 32 で生成)
LOCAL_WORKER_TOKEN=your-random-secret-token-here
MAX_CONCURRENT=1

# ── ローカル動作確認 (共通) ───────────────────────────────────────────────────
# true にすると git clone/push/PR作成・Aider/ADKの実行を全てスキップし、
# ログ出力のみで処理をシミュレートする (HTTP層・認証・Queueリレーの疎通確認用)。
# docker-compose.dev.cloudflare.yml / docker-compose.dev.gcp.yml ではデフォルトtrue。
DRY_RUN=false

# ── Aider + Ollama ────────────────────────────────────────────────────────────
AIDER_MODEL=qwen2.5-coder:32b
OLLAMA_API_BASE=http://localhost:11434/v1

# ── 構成A: Google Cloud ───────────────────────────────────────────────────────
# (Cloud Run上では Secret Manager から自動取得)
GCP_PROJECT=your-gcp-project-id
GEMINI_MODEL=gemini-2.0-flash
AGENT_MODE=GEMINI_ADK
